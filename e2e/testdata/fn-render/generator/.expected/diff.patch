--- /dev/null
+++ b/db/deployment_httpbin.yaml
@@ -0,0 +1,25 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: httpbin
+  namespace: staging
+  labels:
+    app: backend
+    tier: db
+spec:
+  replicas: 4
+  template:
+    spec:
+      containers:
+      - image: kennethreitz/httpbin
+        name: httpbin
+        ports:
+        - containerPort: 9876
+    metadata:
+      labels:
+        app: backend
+        tier: db
+  selector:
+    matchLabels:
+      app: backend
+      tier: db
