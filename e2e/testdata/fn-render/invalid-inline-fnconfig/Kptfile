apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: app
pipeline:
  mutators:
    - image: ghcr.io/kptdev/krm-functions-catalog/set-namespace:latest
      configMap:
        namespace: staging
    - image: ghcr.io/kptdev/krm-functions-catalog/set-labels:v0.1.5
      config: # invalid inline config, missing apiVersion/kind
        envs:
          - dev
          - staging
          - production
        tier: backend
